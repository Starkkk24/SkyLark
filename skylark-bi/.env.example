# ── Monday.com (read-only GraphQL API) ─────────────────────────────
# Personal API token: monday.com → avatar → Developers → My Access Tokens
MONDAY_TOKEN=your_monday_api_token
# Board IDs are the numbers in each board's URL (…/boards/1234567890)
MONDAY_DEALS_BOARD_ID=1234567890
MONDAY_WORKORDERS_BOARD_ID=1234567890

# ── AI provider (swappable) ────────────────────────────────────────
# Which provider to use: "groq" (free, recommended), "gemini", or "openai".
AI_PROVIDER=groq

# Groq — free, fast, OpenAI-compatible, supports tool calling.
# Free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (via its OpenAI-compatible endpoint). Key: https://aistudio.google.com/apikey
# Note: the free tier isn't available in every region — a key can authenticate
# yet still return 429 "limit: 0". If so, enable billing or use another provider.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (used when AI_PROVIDER=openai). Key: https://platform.openai.com/api-keys
# Requires account credits/billing (new keys 429 with insufficient_quota otherwise).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# CUSTOM — any OpenAI-compatible endpoint. Set AI_PROVIDER=custom and fill these.
# Free options that support tool-calling:
#   GitHub Models: AI_BASE_URL=https://models.github.ai/inference  AI_MODEL=openai/gpt-4o-mini   (key = GitHub PAT with "models" access)
#   Cerebras:      AI_BASE_URL=https://api.cerebras.ai/v1          AI_MODEL=llama-3.3-70b         (key from https://cloud.cerebras.ai)
#   OpenRouter:    AI_BASE_URL=https://openrouter.ai/api/v1        AI_MODEL=meta-llama/llama-3.3-70b-instruct   (key from https://openrouter.ai/keys)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ── Business defaults (used by normalization / analytics) ──────────
# Currency assumed when a value has no explicit symbol (₹/$).
DEFAULT_CURRENCY=INR

# ── Auth (OPTIONAL — Phase 10 only; leave blank otherwise) ─────────
# JWT_SECRET=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
